# =============================================
# 生产环境配置示例（华深智药 · 密码自助重置）
# 用法：cp .env.production.example .env  →  填写真实值  →  重启服务
# 重要：.env 含密钥，切勿提交到 git（已在 .gitignore 中）。
# 仅列出应用实际读取的配置项。
# =============================================

# ---- 必填 ----
# Flask 会话签名密钥：用强随机串，至少 32 位
SECRET_KEY=
# 数据库（生产用 PostgreSQL；示例：postgresql://user:pwd@host:5432/dbname）
DATABASE_URL=
# 敏感凭据加密密钥（Fernet key）。生成：
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_ENCRYPTION_KEY=

# ---- 演示模式（生产务必为 false）----
# true=不连真实 AD/短信，用假数据体验；生产必须 false
DEMO_MODE=false

# ---- 管理员初始口令（首次启动建号时使用；留空则默认 admin）----
# 首次启动后建议立即修改，或用 backend/init_admin_password.py 重置
ADMIN_PASSWORD=

# ---- 部署/会话 ----
# 是否启用 HTTPS（true 时 Session Cookie 仅走 HTTPS）
HTTPS_ENABLED=true
# 会话超时（小时）
SESSION_TIMEOUT=8
# 允许的前端来源（多个用逗号；公网部署填实际域名，如 https://pwd.example.com）
CORS_ORIGINS=

# ---- 密码策略 ----
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true

# ---- 日志（可选，均有默认值）----
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760       # 10MB
LOG_BACKUP_COUNT=5

# =============================================
# 部署步骤（Linux 生产）
# 1. 安装：cd backend && python3 -m venv .venv && .venv/bin/pip install -r requirements.txt
# 2. 配置：cp .env.production.example .env，按上面填写（DEMO_MODE=false，真实 PG）
# 3. 迁移：psql 执行 database/2026-06-17-reset-migration.sql
# 4. 启动：用 systemd/nginx（见 systemd/、docs/nginx.conf.example），或 .venv/bin/python app.py
# 5. 后台：浏览器打开 /login（admin / 你设的口令）→ 配置域(AD)、阿里云短信、保护名单
# 注：AAD 密码由已有的 Microsoft Entra Connect 自动同步，本系统不改 AAD。
# =============================================
