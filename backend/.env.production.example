# =============================================
# 生产环境配置文件
# =============================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 根据实际情况修改配置项
# 3. 确保 .env 文件不被提交到版本控制
# =============================================

# ---------------------------------------------
# Flask 基础配置
# ---------------------------------------------
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=<生成一个强随机密钥，至少 32 位>

# ---------------------------------------------
# 数据库配置
# ---------------------------------------------
# SQLite（开发/测试环境）
DATABASE_URL=sqlite:///backend/instance/ad_password.db

# PostgreSQL（生产环境 - 取消注释并使用）
# DATABASE_URL=postgresql://username:password@localhost:5432/ad_password_db

# MySQL（生产环境 - 取消注释并使用）
# DATABASE_URL=mysql://username:password@localhost:3306/ad_password_db

# ---------------------------------------------
# 安全配置
# ---------------------------------------------
# Session Cookie 安全设置
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# Session 有效期（秒）
PERMANENT_SESSION_LIFETIME=28800  # 8 小时

# CSRF 保护
WTF_CSRF_ENABLED=True
WTF_CSRF_TIME_LIMIT=3600  # 1 小时

# ---------------------------------------------
# LDAP/AD 配置
# ---------------------------------------------
LDAP_HOST=192.168.1.226
LDAP_PORT=389
LDAP_USE_SSL=False
LDAP_USE_TLS=False

# LDAPS（SSL 加密）配置
# LDAP_HOST=192.168.1.226
# LDAP_PORT=636
# LDAP_USE_SSL=True

# LDAP 基础 DN
LDAP_BASE_DN=DC=helixon,DC=com

# LDAP 管理员 DN（用于搜索和同步）
LDAP_ADMIN_DN=CN=Administrator,CN=Users,DC=helixon,DC=com

# LDAP 管理员密码（建议使用密钥管理服务）
LDAP_PASSWORD=<您的 LDAP 管理员密码>

# ---------------------------------------------
# MFA/2FA 配置
# ---------------------------------------------
# MFA 发行者名称
MFA_ISSUER_NAME=AD Password System

# MFA 验证时间窗口（秒）
MFA_VALID_WINDOW=30

# 是否强制要求 MFA
MFA_REQUIRED_FOR_PASSWORD_CHANGE=True
MFA_REQUIRED_FOR_LOGIN=False  # 建议逐步启用

# ---------------------------------------------
# 密码策略配置
# ---------------------------------------------
# 最小密码长度
MIN_PASSWORD_LENGTH=8

# 密码复杂度要求
PASSWORD_REQUIRE_UPPERCASE=True
PASSWORD_REQUIRE_LOWERCASE=True
PASSWORD_REQUIRE_DIGIT=True
PASSWORD_REQUIRE_SPECIAL=True

# 密码历史（防止重复使用）
PASSWORD_HISTORY_COUNT=5

# 密码有效期（天）
PASSWORD_MAX_AGE_DAYS=90

# ---------------------------------------------
# 日志配置
# ---------------------------------------------
# 日志级别：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=logs/app.log

# 日志文件大小（MB）
LOG_MAX_BYTES=10485760  # 10MB

# 日志文件备份数量
LOG_BACKUP_COUNT=10

# ---------------------------------------------
# 短信服务配置（可选 - 阿里云）
# ---------------------------------------------
ALIYUN_ACCESS_KEY_ID=<您的 AccessKey ID>
ALIYUN_ACCESS_KEY_SECRET=<您的 AccessKey Secret>
ALIYUN_SIGN_NAME=<您的短信签名>
ALIYUN_TEMPLATE_CODE=<短信模板代码>

# 短信验证码有效期（秒）
SMS_CODE_EXPIRY=300  # 5 分钟

# 短信发送频率限制（次/分钟）
SMS_RATE_LIMIT=5

# ---------------------------------------------
# CAS 单点登录配置（可选）
# ---------------------------------------------
CAS_SERVER_URL=https://cas.example.com/cas
CAS_LOGIN_URL=/login
CAS_LOGOUT_URL=/logout
CAS_VERIFY_SSL=True

# ---------------------------------------------
# 系统配置
# ---------------------------------------------
# 系统名称
SYSTEM_NAME=AD 密码管理系统

# 系统版本
SYSTEM_VERSION=1.0.0

# 最大用户数限制
MAX_USERS=1000

# 最大并发数
MAX_CONCURRENT_REQUESTS=100

# ---------------------------------------------
# 监控与告警配置
# ---------------------------------------------
# 启用健康检查端点
HEALTH_CHECK_ENABLED=True

# 启用性能监控
PERFORMANCE_MONITORING_ENABLED=False

# 告警邮件地址（多个地址用逗号分隔）
ALERT_EMAIL=admin@example.com

# 告警阈值
ERROR_RATE_THRESHOLD=0.05  # 5% 错误率
RESPONSE_TIME_THRESHOLD=2.0  # 2 秒响应时间

# ---------------------------------------------
# 其他配置
# ---------------------------------------------
# 启用 CORS
CORS_ENABLED=True
CORS_ORIGINS=*
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization

# 启用 Gzip 压缩
GZIP_ENABLED=True
GZIP_MIN_LENGTH=1024

# 文件上传限制（MB）
MAX_UPLOAD_SIZE=10

# 允许的文件扩展名
ALLOWED_EXTENSIONS=png,jpg,jpeg,gif,pdf,doc,docx,xls,xlsx
