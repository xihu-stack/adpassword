# Flask 配置
SECRET_KEY=your-super-secret-key-change-this-in-production

# 数据库配置
DATABASE_URL=postgresql://aduser:YourPassword@localhost/ad_password_db

# CAS 配置（根据实际情况修改）
CAS_SERVER_LOGIN_URL=https://cas.example.com/login
CAS_SERVER_LOGOUT_URL=https://cas.example.com/logout
CAS_SERVER_VALIDATE_URL=https://cas.example.com/p3/serviceValidate
CAS_AFTER_LOGIN_URL=http://localhost:5000/cas/callback

# CORS 配置（前端地址）
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 敏感凭据加密密钥（Fernet key；生成命令见下）
# 生成：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_ENCRYPTION_KEY=

# 密码策略
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true
